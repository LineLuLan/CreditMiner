# =============================================================================
# CreditMiner backend — environment template
# Copy to backend/.env (gitignored) and fill in values for your environment.
# =============================================================================

# Active Spring profile: dev (local Postgres) | prod (Neon)
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# Dev profile — local Postgres (docker-compose). Defaults below match
# application-dev.yml, override only if your local setup differs.
# -----------------------------------------------------------------------------
# DATABASE_URL=jdbc:postgresql://localhost:5432/creditminer_db
# DB_USER=creditminer
# DB_PASSWORD=creditminer

# -----------------------------------------------------------------------------
# Prod profile — Neon Postgres (ap-southeast-1).
# IMPORTANT:
#   - Spring's PostgreSQL driver expects the JDBC URL form: jdbc:postgresql://<host>/<db>?...
#   - Move user/password OUT of the URI into DB_USER / DB_PASSWORD env vars
#     (Neon's web UI gives a postgresql:// URI; convert before pasting here).
#   - Keep sslmode=require for Neon. channel_binding is optional.
# -----------------------------------------------------------------------------
# DATABASE_URL=jdbc:postgresql://ep-purple-smoke-aosu7szo-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# DB_USER=neondb_owner
# DB_PASSWORD=<paste from Neon console>

# -----------------------------------------------------------------------------
# CORS — frontend origin allowed in prod (dev is hard-coded to localhost:3000)
# -----------------------------------------------------------------------------
# CM_FRONTEND_URL=https://creditminer-demo.vercel.app

# -----------------------------------------------------------------------------
# Optional path overrides (rarely needed; defaults in application.yml are fine)
# -----------------------------------------------------------------------------
# CM_RAW_CSV=data/raw/BankChurners.csv
# CM_PROCESSED_ARFF=data/processed/clean.arff
# CM_MODEL_CLASSIFIER=models/rf.model
# CM_MODEL_CLUSTERER=models/kmeans.model
# SERVER_PORT=8080
