# =============================================================================
# CreditMiner Web — local development environment variables
# Copy to .env.local and fill in real values.
# =============================================================================

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Optional: enable Next.js rewrites proxy (avoids CORS in dev)
# When true, frontend fetches go to /api/* and Next proxies to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_PROXY=false

# App branding
NEXT_PUBLIC_APP_NAME=CreditMiner

# Toggle dark mode default (light | dark | system)
NEXT_PUBLIC_DEFAULT_THEME=system
